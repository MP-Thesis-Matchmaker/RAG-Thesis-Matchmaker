# Copy this file to .env and fill in what you need.
# .env is gitignored. Never commit real keys.

# LLM endpoint for parsing the student's query (OpenAI-compatible).
# Production: point at LibreChat / the AI Buddy gateway.
# Development: point at a free local model, e.g. Ollama:
#   LLM_BASE_URL=http://localhost:11434/v1
# Leave LLM_BASE_URL empty to use the offline rule-based parser (no LLM needed).
LLM_BASE_URL=
LLM_MODEL=llama3.1
LLM_API_KEY=

# Embedding model for semantic search (provisional default).
# Requires the 'embeddings' extra (uv sync --extra embeddings); the model
# (~4 GB) downloads to ~/.cache/huggingface on first use.
# Set to hash-fake for the deterministic offline embedder (no download,
# no real semantics) - used by tests, CI, and quick demos.
EMBEDDING_MODEL=BAAI/bge-m3

# Where the vector index is stored. Built with: thesis-matchmaker index
VECTOR_STORE_PATH=data/index

# Directory with the ingestion output the indexer reads
# (publications.jsonl / theses.jsonl). Defaults to the synthetic sample data.
SOURCES_PATH=data/samples

# Name of the vector store collection holding the index.
COLLECTION_NAME=matchmaker

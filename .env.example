# Copy this file to .env and fill in what you need.
# .env is gitignored. Never commit real keys.

# LLM endpoint for parsing the student's query (OpenAI-compatible).
# Production: point at LibreChat / the AI Buddy gateway.
# Development: point at a free local model, e.g. Ollama:
#   LLM_BASE_URL=http://localhost:11434/v1
# Leave LLM_BASE_URL empty to use the offline rule-based parser (no LLM needed).
LLM_BASE_URL=
LLM_MODEL=llama3.1
LLM_API_KEY=

# Embedding model for semantic search (provisional default).
EMBEDDING_MODEL=BAAI/bge-m3

# Where the vector index will be stored once it exists.
VECTOR_STORE_PATH=data/index
